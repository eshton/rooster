{
  "name": "@rooster/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema, migrations and a runtime-selected driver abstraction (Postgres + libSQL/SQLite).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -b",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.config.sqlite.ts",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.config.pg.ts",
    "db:migrate": "node dist/migrate.js",
    "db:seed": "node dist/seed.js"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "@rooster/config": "workspace:*",
    "@rooster/schema": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10"
  }
}
