# =============================================================================
# Rooster — environment configuration
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# All keys are validated at startup by @rooster/config (zod).
# =============================================================================

# --- Core -------------------------------------------------------------------

# Runtime environment: development | test | production
NODE_ENV=development

# Public base URL of this deployment (used for OAuth redirects + MCP metadata).
# No trailing slash.
ROOSTER_BASE_URL=http://localhost:3000

# Port for the local Node server (ignored on Vercel/Cloudflare).
PORT=3000

# Deployment adapter: node | vercel | cloudflare
# Usually auto-detected; set explicitly to override.
# ROOSTER_PLATFORM=node

# --- Database ---------------------------------------------------------------
# The DB driver is chosen purely from the DATABASE_URL scheme:
#   postgres:// | postgresql://  -> PostgreSQL
#   file:                        -> local SQLite file
#   libsql:// | https://         -> libSQL / Turso
#
# Local SQLite (default for dev / single-host self-host):
DATABASE_URL=file:./local.db
#
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/rooster
#
# Turso / libSQL (auth token required for remote):
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=

# --- Auth: signing keys -----------------------------------------------------
# Secret used by better-auth to sign sessions/tokens. Generate with:
#   openssl rand -base64 32
ROOSTER_AUTH_SECRET=replace-me-with-a-32-byte-random-secret

# --- Auth: human OAuth providers (better-auth) ------------------------------
# Optional social login. Email/password works without any of these; set a
# provider's id+secret to add a "Continue with …" button (buttons appear only
# for configured providers). Callback URL: <base-url>/api/auth/callback/<prov>.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Additional providers (all optional, same pattern):
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=

# Require email verification before sign-in. Opt-in, and only enforced when a
# real email sender (Resend / webhook, below) is configured — otherwise it stays
# off so users can't be locked out. Accepts true/1.
# ROOSTER_REQUIRE_EMAIL_VERIFICATION=true

# --- Agent enrollment policy ------------------------------------------------
# How new agents (OAuth Dynamic Client Registration) are admitted to an org:
#   token    -> a valid org enrollment token is required (default)
#   approval -> a human owner/admin must approve the pending registration
#   open     -> any client may self-register (NOT recommended outside dev)
ROOSTER_ENROLLMENT_POLICY=token

# Optional shared bootstrap enrollment token for the `token` policy.
# Per-org tokens are managed in the dashboard; this is a fallback for dev.
# ROOSTER_ENROLLMENT_TOKEN=

# --- Tenant onboarding gate -------------------------------------------------
# Gates agent-first tenant self-registration (POST /onboard).
#   set    -> callers must present a matching signupToken (hosted instances)
#   unset  -> open registration (convenient for self-host / dev)
# ROOSTER_SIGNUP_TOKEN=

# --- Self-host: closed signup + first-run admin -----------------------------
# Close public email/password sign-up (the dashboard form). New members then
# join only by invite. For internal teams / single-user instances. true|1.
# ROOSTER_DISABLE_SIGNUP=true
#
# Optional first-run admin: when email+password are set and the email has no
# Rooster user yet, the Node entry creates the account + a starter workspace on
# startup (works even with sign-up disabled). The "just me" zero-setup path —
# set these, start, log in. Password >= 8 chars.
# ROOSTER_ADMIN_EMAIL=you@example.com
# ROOSTER_ADMIN_PASSWORD=change-me-at-least-8-chars
# ROOSTER_ADMIN_WORKSPACE=My Workspace   # optional, default "My Workspace"
# ROOSTER_ADMIN_PROJECT_KEY=TASK         # optional, default "TASK"

# --- Rate limiting ----------------------------------------------------------
# Max MCP tool calls per agent per minute.
ROOSTER_MCP_RATE_LIMIT_PER_MINUTE=120

# TTL (seconds) for the resolved-actor cache on the /mcp hot path. A short
# window skips the identity-resolution chain on repeat calls; role/scope/
# membership changes self-heal within it. Set 0 to disable.
ROOSTER_MCP_ACTOR_CACHE_TTL_SECONDS=30

# --- Notifications ----------------------------------------------------------
# Optional outbound webhook for `crow` (assignee wake) notifications. When set,
# a crow POSTs a JSON payload here; delivery is best-effort and never fails the
# crow. Leave unset to keep crow audit-only.
# ROOSTER_CROW_WEBHOOK_URL=https://example.com/hooks/rooster-crow
#
# Transactional email (password reset). Delivery is chosen in priority order:
# Resend → webhook → stdout. Configure ONE for production.
#
# 1. Resend (https://resend.com) — the edge-friendly default for the hosted
#    instance. Needs both the API key and a from-address on a domain you've
#    verified in Resend (DNS records), or mail won't be delivered.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# ROOSTER_EMAIL_FROM=Rooster <no-reply@your-domain.com>
#
# 2. Webhook — Rooster POSTs the message ({type:'email', to, subject, text,
#    kind, url}) to your endpoint for your own service to deliver.
# ROOSTER_EMAIL_WEBHOOK_URL=https://example.com/hooks/rooster-email
#
# With none of the above set, the reset link is logged to stdout (fine for
# dev/self-host; not for production).
