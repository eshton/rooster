# =============================================================================
# Rooster — environment configuration
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# All keys are validated at startup by @rooster/config (zod).
# =============================================================================

# --- Core -------------------------------------------------------------------

# Runtime environment: development | test | production
NODE_ENV=development

# Public base URL of this deployment (used for OAuth redirects + MCP metadata).
# No trailing slash.
ROOSTER_BASE_URL=http://localhost:3000

# Port for the local Node server (ignored on Vercel/Cloudflare).
PORT=3000

# Deployment adapter: node | vercel | cloudflare
# Usually auto-detected; set explicitly to override.
# ROOSTER_PLATFORM=node

# --- Database ---------------------------------------------------------------
# The DB driver is chosen purely from the DATABASE_URL scheme:
#   postgres:// | postgresql://  -> PostgreSQL
#   file:                        -> local SQLite file
#   libsql:// | https://         -> libSQL / Turso
#
# Local SQLite (default for dev / single-host self-host):
DATABASE_URL=file:./local.db
#
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/rooster
#
# Turso / libSQL (auth token required for remote):
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=

# --- Auth: signing keys -----------------------------------------------------
# Secret used by better-auth to sign sessions/tokens. Generate with:
#   openssl rand -base64 32
ROOSTER_AUTH_SECRET=replace-me-with-a-32-byte-random-secret

# --- Auth: human OAuth providers (better-auth) ------------------------------
# At least one provider is required for human dashboard login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Agent enrollment policy ------------------------------------------------
# How new agents (OAuth Dynamic Client Registration) are admitted to an org:
#   token    -> a valid org enrollment token is required (default)
#   approval -> a human owner/admin must approve the pending registration
#   open     -> any client may self-register (NOT recommended outside dev)
ROOSTER_ENROLLMENT_POLICY=token

# Optional shared bootstrap enrollment token for the `token` policy.
# Per-org tokens are managed in the dashboard; this is a fallback for dev.
# ROOSTER_ENROLLMENT_TOKEN=

# --- Tenant onboarding gate -------------------------------------------------
# Gates agent-first tenant self-registration (POST /onboard).
#   set    -> callers must present a matching signupToken (hosted instances)
#   unset  -> open registration (convenient for self-host / dev)
# ROOSTER_SIGNUP_TOKEN=

# --- Rate limiting ----------------------------------------------------------
# Max MCP tool calls per agent per minute.
ROOSTER_MCP_RATE_LIMIT_PER_MINUTE=120

# --- Notifications ----------------------------------------------------------
# Optional outbound webhook for `crow` (assignee wake) notifications. When set,
# a crow POSTs a JSON payload here; delivery is best-effort and never fails the
# crow. Leave unset to keep crow audit-only.
# ROOSTER_CROW_WEBHOOK_URL=https://example.com/hooks/rooster-crow
#
# Optional outbound webhook for transactional email (password reset). When set,
# Rooster POSTs the message ({type:'email', to, subject, text, kind, url}) here
# for your service to deliver. Leave unset to log the link to stdout instead
# (fine for dev/self-host; configure a real sender in production so users can
# reset their password).
# ROOSTER_EMAIL_WEBHOOK_URL=https://example.com/hooks/rooster-email
