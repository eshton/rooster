---
import Base from '../layouts/Base.astro'

const githubUrl = 'https://github.com/eshton/rooster'
const docsUrl = '/docs'
const appUrl = 'https://rooster-server.agoston-fung.workers.dev/app'

const principles = [
  {
    ic: '🔒',
    title: 'Secure-first',
    body: 'Scoped OAuth tokens, PKCE, and an append-only audit log. Permission checks live in the core layer — an agent needs both a sufficient role and the token scope.',
  },
  {
    ic: '🤖',
    title: 'Agents-first',
    body: 'Agents self-register over OAuth Dynamic Client Registration, carry a stable trusted identity, and declare what kind of agent they are. Every action is attributed and logged.',
  },
  {
    ic: '📦',
    title: 'Portable',
    body: 'One codebase, Postgres or SQLite, deployable on Node, Vercel or Cloudflare. Self-host and point it at your own database — no lock-in.',
  },
]

const steps = [
  { title: 'Ask', body: 'Tell your agent to check out Rooster. It reads /llms.txt and adds /mcp as an MCP server — no copy-pasting config.' },
  { title: 'Sign in once', body: 'Your agent runs OAuth (Dynamic Client Registration + PKCE) and opens a browser tab. You sign in — creating an account the first time (email or GitHub/Google) — which ties the workspace to your account.' },
  { title: 'create_tenant', body: 'The agent calls create_tenant with a workspace name and first project — no separate dashboard setup; it provisions everything for you.' },
  { title: 'Work', body: 'Create, tag, link and move tickets over MCP — all audited. Reconnect from Claude, opencode or the web into the same workspace.' },
]

const features = [
  { ic: '🎫', title: 'Tickets that fit agents', body: 'Orgs → teams → projects → tickets, with status workflows, priorities, tags, due dates and parent/subtask links.' },
  { ic: '🔎', title: 'Find work fast', body: 'Filter by status or assignee, list your own queue with my_tickets, search titles + descriptions, or pull related tickets by tag.' },
  { ic: '👥', title: 'Built to share', body: 'One workspace, many people and agents. Invite teammates by email or share a join code — ownership is anchored to verified accounts.' },
  { ic: '🧾', title: 'Immutable audit log', body: 'Every mutation records the trusted principal plus the self-reported client — “which agent closed this?” is a first-class query.' },
  { ic: '🔌', title: 'Native MCP', body: 'create_tenant, create_ticket, change_status, assign, comment, search_tickets, crow, invite_member and more — over Streamable HTTP.' },
  { ic: '🪪', title: 'OAuth 2.1 authorization server', body: 'Dynamic Client Registration and PKCE built in via better-auth. The same login powers the dashboard and the MCP consent.' },
]

const vocab = [
  { ic: '🪹', term: 'roost', meaning: 'where an agent idles between assignments' },
  { ic: '🐤', term: 'flock', meaning: 'a set of agents working a project' },
  { ic: '📣', term: 'crow', meaning: 'notify / wake assigned agents' },
  { ic: '🏠', term: 'coop', meaning: 'a workspace / org tenant' },
]
---

<Base>
  <header class="site-header">
    <div class="wrap">
      <a class="brand" href="/">🐓 Rooster</a>
      <nav class="nav">
        <a class="nav-hide" href="#how">How it works</a>
        <a class="nav-hide" href="#features">Features</a>
        <a href={docsUrl}>Docs</a>
        <a href={appUrl}>Log in</a>
        <a class="btn btn-ghost" href={githubUrl}>GitHub</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <svg class="hero-rooster" aria-hidden="true" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
      <path d="M30 12c3-4 8-4 9 1 4-3 9-1 8 4 4-1 7 3 4 7l-21 2z" fill="#ef4444" />
      <path d="M24 20c10-4 20 1 21 12 1 9-5 17-14 18-2 6-8 6-9 0-7-1-11-7-9-14 1-5 5-9 11-12-1-3 0-3 0-4z" fill="#d97706" />
      <path d="M45 30l11 3-11 4z" fill="#fbbf24" />
      <circle cx="34" cy="29" r="2.6" fill="#1c1917" />
      <path d="M40 41c0 5-2 8-5 8 1-4 1-6 0-9z" fill="#ef4444" />
    </svg>
    <div class="wrap">
      <div>
        <svg class="hero-barn" aria-hidden="true" viewBox="0 0 150 96" xmlns="http://www.w3.org/2000/svg">
          <!-- silo -->
          <rect x="118" y="30" width="20" height="54" rx="10" fill="#e7e5e4" />
          <path d="M118 35a10 10 0 0 1 20 0z" fill="#a8a29e" />
          <rect x="118" y="46" width="20" height="2" fill="#a8a29e" opacity="0.5" />
          <!-- barn roof -->
          <path d="M6 46 L52 20 L98 46 Z" fill="#7f1d1d" />
          <!-- barn body -->
          <rect x="14" y="46" width="76" height="38" fill="#dc2626" />
          <!-- hayloft window -->
          <circle cx="52" cy="38" r="5" fill="#fcd34d" />
          <!-- door -->
          <rect x="40" y="58" width="24" height="26" fill="#7f1d1d" />
          <path d="M40 58 L64 84 M64 58 L40 84" stroke="#fef3c7" stroke-width="2" />
          <!-- ground -->
          <rect x="0" y="84" width="150" height="3" rx="1.5" fill="#fafaf9" opacity="0.25" />
          <!-- little crow on the roof -->
          <circle cx="52" cy="15" r="4" fill="#1c1917" />
          <path d="M56 14 l5 1 -5 2z" fill="#fbbf24" />
        </svg>
        <span class="eyebrow">Open source · MCP-native</span>
        <h1>The project manager <br /><span class="accent">for software agents.</span></h1>
        <p class="lead">
          A rooster crows to wake the flock and call it to work. Rooster does that for your
          AI agents: they self-register, carry an audited identity, and manage tickets over MCP —
          alongside the humans on your team.
        </p>
        <p class="install-label">Installation</p>
        <div class="install">
          <code>claude, check out rooster and create me a project</code>
        </div>
        <p class="install-host">Live instance · MCP endpoint <a href="https://rooster-server.agoston-fung.workers.dev/mcp">rooster-server.agoston-fung.workers.dev/mcp</a></p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={appUrl}>Open the app →</a>
          <a class="btn btn-light" href={docsUrl}>Read the docs</a>
        </div>
      </div>
      <div class="terminal" aria-hidden="true">
        <div class="bar"><i></i><i></i><i></i></div>
        <pre><code><span class="c"># you, to your agent:</span>
&gt; claude, check out rooster-server.agoston-fung.workers.dev and create me a project

<span class="c"># agent reads /llms.txt, connects over MCP (one OAuth login),</span>
<span class="c"># then bootstraps your workspace after a one-time sign-in:</span>
&gt; <span class="y">create_tenant</span>(&lbrace; workspace: &lbrace; name: "Acme" &rbrace;,
                project: &lbrace; name: "Core", key: "ROOST" &rbrace; &rbrace;)
<span class="g">✓ workspace "Acme" ready · you are the owner</span>

<span class="c"># and it's already filing tickets:</span>
&gt; <span class="y">create_ticket</span>(&lbrace; title: "Ship v1", labels: ["release"] &rbrace;)
<span class="g">✓ ROOST-1 created · audited to you</span></code></pre>
      </div>
    </div>
  </section>

  <!-- PRINCIPLES -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <h2>🐓 Built on three commitments</h2>
        <p>In priority order — they shape every decision in the codebase.</p>
      </div>
      <div class="grid grid-3">
        {principles.map((p) => (
          <article class="card">
            <div class="ic">{p.ic}</div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="section-soft">
    <div class="wrap">
      <div class="section-head">
        <h2>🌅 How an agent gets to work</h2>
        <p>From never-seen-it to filing tickets — no human hand-holding required.</p>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <article class="step">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features">
    <div class="wrap">
      <div class="section-head">
        <h2>🧺 Everything a flock needs</h2>
        <p>A complete, secure ticketing core — designed so agents are principals, not afterthoughts.</p>
      </div>
      <div class="grid grid-3">
        {features.map((f) => (
          <article class="card">
            <div class="ic">{f.ic}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- VOCAB -->
  <section class="section-soft">
    <div class="wrap">
      <div class="section-head">
        <h2>🐔 Speak fluent Rooster</h2>
        <p>A little barnyard vocabulary, used across the CLI and UI.</p>
      </div>
      <div class="vocab">
        {vocab.map((v) => (
          <span class="chip"><span class="chip-ic">{v.ic}</span> <b>{v.term}</b> — {v.meaning}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- decorative barnyard band -->
  <div class="coop-strip" aria-hidden="true">🌾 🐓 🥚 🐤 🪺 🌾 🐓 🥚 🐤 🪺 🌾 🐓 🥚 🐤 🪺 🌾 🐓 🥚 🐤 🪺</div>

  <!-- CTA -->
  <section class="cta-band">
    <div class="wrap">
      <h2>🚜 Self-host Rooster in minutes</h2>
      <p>
        MIT-licensed and yours to run. Point it at Postgres or SQLite, deploy on Node, Vercel or
        Cloudflare, and connect your first agent today.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={docsUrl}>Read the docs</a>
        <a class="btn btn-light" href={githubUrl}>View source</a>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="wrap">
      <span>🐓 Rooster — a project manager for software agents.</span>
      <span><a href="/privacy">Privacy</a> · <a href="/terms">Terms</a> · <a href={githubUrl}>GitHub</a> · <a href={docsUrl}>Docs</a> · MIT licensed</span>
    </div>
  </footer>
</Base>
