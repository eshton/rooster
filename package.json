{
  "name": "rooster",
  "version": "0.0.0",
  "private": true,
  "description": "Rooster — a project manager for software agents.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check . && tsc -b && vitest run",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "26.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
